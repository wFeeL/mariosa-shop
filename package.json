{
  "name": "mariosa-jewelry-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5217 --strictPort",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4217 --strictPort",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "node scripts/browser-qa.mjs"
  },
  "dependencies": {
    "@fontsource/manrope": "^5.1.1",
    "@fontsource/prata": "^5.2.7",
    "@phosphor-icons/react": "^2.1.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vitest": "^3.2.7"
  }
}
